# ============================================
# 雨润Claw 后端环境变量
# ============================================

# --- Supabase 数据库（必须）---
COZE_SUPABASE_URL=https://你的项目.supabase.co
COZE_SUPABASE_ANON_KEY=你的anon_key
COZE_SUPABASE_SERVICE_ROLE_KEY=你的service_role_key

# --- AI 模式选择（二选一）---

# 模式A：小艺Claw 对接（推荐，速度快）
AI_SOURCE=claw

# 模式B：本地大模型（无需联网，但速度慢）
# 去掉下面两行前面的 # 即可切换
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# 服务端口号（默认 9091）
PORT=9091
